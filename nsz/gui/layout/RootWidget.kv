<RootWidget>:
	ScreenManager:
		id: sm

		Screen:
			name: 'screen1'
			BoxLayout:
				pos_hint: {'x': .05, 'y': .05}
				size_hint: (.9, .9)
				orientation: 'vertical'
				spacing: 8
				StackLayout:
					size_hint_y: None
					height: 100
					spacing: 8
					Button:
						id: btn_compress
						background_normal: ''
						background_color: (0.1, 0.5, 0.3, 0.7) if not root.is_working else (0.3, 0.3, 0.3, 0.5)
						color: 1, 1, 1, 1
						size_hint: (.29, .45)
						font_size: 0.35 * self.height
						text: 'Compress NSP/XCI'
						on_release: root.Compress()
						disabled: root.is_working
					Button:
						id: btn_decompress
						background_normal: ''
						background_color: (0.5, 0.3, 0.2, 0.7) if not root.is_working else (0.3, 0.3, 0.3, 0.5)
						color: 1, 1, 1, 1
						size_hint: (.29, .45)
						font_size: 0.35 * self.height
						text: 'Decompress NSZ/XCZ'
						on_release: root.Decompress()
						disabled: root.is_working
					Button:
						id: btn_input
						background_normal: ''
						background_color: (0.1, 0.3, 0.5, 0.7) if not root.is_working else (0.3, 0.3, 0.3, 0.5)
						color: 1, 1, 1, 1
						size_hint: (.21, .45)
						font_size: 0.35 * self.height
						text: 'Select Input'
						on_release: root.showInputFileFolderDialog()
						disabled: root.is_working
					Button:
						id: btn_output
						background_normal: ''
						background_color: (0.1, 0.3, 0.5, 0.7) if not root.is_working else (0.3, 0.3, 0.3, 0.5)
						color: 1, 1, 1, 1
						size_hint: (.21, .45)
						font_size: 0.35 * self.height
						text: 'Select Output'
						on_release: root.showOutputFileFolderDialog()
						disabled: root.is_working
					Button:
						id: btn_settings
						background_normal: ''
						background_color: (0.3, 0.2, 0.4, 0.7) if not root.is_working else (0.3, 0.3, 0.3, 0.5)
						color: 1, 1, 1, 1
						size_hint: (.105, .45)
						font_size: 0.35 * self.height
						text: 'Settings'
						on_release: app.open_settings()
						disabled: root.is_working
					Button:
						id: btn_about
						background_normal: ''
						background_color: (0.3, 0.2, 0.4, 0.7) if not root.is_working else (0.3, 0.3, 0.3, 0.5)
						color: 1, 1, 1, 1
						size_hint: (.105, .45)
						font_size: 0.35 * self.height
						text: 'About'
						on_release: root.showAboutDialog()
						disabled: root.is_working
					Button:
						id: btn_verify
						background_normal: ''
						background_color: (0.2, 0.4, 0.5, 0.7) if not root.is_working else (0.3, 0.3, 0.3, 0.5)
						color: 1, 1, 1, 1
						size_hint: (.105, .45)
						font_size: 0.35 * self.height
						text: 'Verify'
						on_release: root.Verify()
						disabled: root.is_working
					Button:
						id: btn_info
						background_normal: ''
						background_color: (0.4, 0.3, 0.5, 0.7) if not root.is_working else (0.3, 0.3, 0.3, 0.5)
						color: 1, 1, 1, 1
						size_hint: (.105, .45)
						font_size: 0.35 * self.height
						text: 'Info'
						on_release: root.Info()
						disabled: root.is_working
					Button:
						id: btn_titlekey
						background_normal: ''
						background_color: (0.3, 0.4, 0.3, 0.7) if not root.is_working else (0.3, 0.3, 0.3, 0.5)
						color: 1, 1, 1, 1
						size_hint: (.105, .45)
						font_size: 0.35 * self.height
						text: 'Titlekey'
						on_release: root.Titlekeys()
						disabled: root.is_working
					Button:
						id: btn_extract
						background_normal: ''
						background_color: (0.4, 0.2, 0.3, 0.7) if not root.is_working else (0.3, 0.3, 0.3, 0.5)
						color: 1, 1, 1, 1
						size_hint: (.105, .45)
						font_size: 0.35 * self.height
						text: 'Extract'
						on_release: root.Extract()
						disabled: root.is_working


				BoxLayout:
					id: inFilesLayout
					canvas.before:
						Color:
							rgba: (0.05, 0.05, 0.15, 0.5)
						RoundedRectangle:
							pos: self.pos
							size: self.size
							radius: [10, 10, 10, 10]
							
		Screen:
			name: 'screen2'
		Screen:
			name: 'screen3'
