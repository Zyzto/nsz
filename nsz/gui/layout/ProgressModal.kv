<ProgressModal>:
    canvas.before:
        Color:
            rgba: 0.05, 0.05, 0.15, 0.95
        RoundedRectangle:
            size: root.size
            pos: root.pos
            radius: [15, 15, 15, 15]
    
    BoxLayout:
        orientation: "vertical"
        padding: 25
        spacing: 15
        
        Label:
            id: operation_label
            text: root.operation_name
            font_size: 22
            color: 0.9, 0.9, 1.0, 1.0
            size_hint_y: None
            height: 35
        
        Label:
            id: file_label
            text: root.current_file
            font_size: 14
            color: 0.5, 0.7, 1.0, 1.0
            size_hint_y: None
            height: 25
            text_size: self.width, None
            valign: "middle"
        
        BoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: 22
            Label:
                text: "File:"
                font_size: 12
                color: 0.5, 0.5, 0.5, 1.0
                size_hint_x: 0.15
            Label:
                text: str(root.current_file_index) + " / " + str(root.total_files)
                font_size: 12
                color: 0.6, 0.8, 1.0, 1.0
                size_hint_x: 0.85
        
        BoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: 28
            Label:
                id: status_label
                text: root.status_text
                font_size: 14
                color: 0.6, 0.8, 1.0, 1.0
                size_hint_x: 0.7
            Label:
                id: percent_label
                text: str(int(root.progress_percent)) + "%"
                font_size: 16
                color: 0.4, 0.9, 0.4, 1.0
                size_hint_x: 0.3
                halign: "right"
        
        ProgressBar:
            id: progress_bar
            value: root.progress_percent
            max: 100
            size_hint_y: None
            height: 18
            canvas:
                Color:
                    rgba: root.progress_color
                Rectangle:
                    pos: self.pos
                    size: self.size
        
        BoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: 40
            spacing: 15
            
            Button:
                id: cancel_btn
                text: "Cancel"
                background_normal: ""
                background_color: (0.6, 0.3, 0.3, 0.8)
                color: 1, 1, 1, 1
                font_size: 14
            
            Button:
                id: close_btn
                text: "Close"
                background_normal: ""
                background_color: (0.2, 0.5, 0.8, 0.8)
                color: 1, 1, 1, 1
                font_size: 14
                on_release: root.close()
                opacity: 0
                disabled: True