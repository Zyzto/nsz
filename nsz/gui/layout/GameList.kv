<SelectableLabel>:
	canvas.before:
		Color:
			rgba: (0.2, 0.4, 0.8, 0.4) if self.selected else (0.1, 0.1, 0.2, 0.3)
		Rectangle:
			pos: self.pos
			size: self.size
	cover_source: ''
	filename_text: ''
	titleid: ''
	version: ''
	filesize_text: '0 KB'
	pos: self.pos
	size: self.size
	on_size: self.height = self.ids.id_filename.height
	Label:
		id: id_filename
		valign: "top"
		halign: "left"
		pos: 0, 0
		size_hint: None, None
		text_size: self.width, None
		font_size: 13
		color: 0.9, 0.9, 1.0, 1.0
		text: root.filename_text
		size: root.width-300, self.texture_size[1]
		on_size: root.height = self.height
		padding: [5, 3]
		canvas.before:
			Color:
				rgba: (0.0, 0.3, 0.5, 0.15)
			Rectangle:
				pos: self.pos
				size: self.size
	Label:
		id: id_titleid
		valign: "top"
		halign: "right"
		pos: root.width-300, 0
		size_hint: None, None
		text_size: self.width, root.height
		font_size: 12
		color: 0.3, 0.8, 0.3, 1.0
		text: root.titleid
		size: 140, self.texture_size[1]
		padding: [3, 2]
	Label:
		id: id_version
		valign: "top"
		halign: "right"
		pos: root.width-160, 0
		size_hint: None, None
		text_size: self.width, root.height
		font_size: 12
		color: 0.8, 0.6, 0.2, 1.0
		text: root.version
		size: 80, self.texture_size[1]
		padding: [3, 2]
	Label:
		id: id_size
		valign: "top"
		halign: "right"
		pos: root.width-80, 0
		size_hint: None, None
		text_size: self.width, root.height
		font_size: 12
		color: 0.6, 0.8, 1.0, 1.0
		text: root.filesize_text
		size: 80, self.texture_size[1]
		padding: [3, 2]

<RV>:
	scroll_y: 0.5
	viewclass: 'SelectableLabel'
	SelectableRecycleBoxLayout:
		id: selectableRecycleBoxLayout
		default_size: None, dp(44)
		default_size_hint: 0.99, None
		size_hint_y: None
		height: self.minimum_height
		orientation: 'vertical'
		multiselect: True
		touch_multiselect: True


<GameList>:
	FloatLayout:
		id: DragAndDropFloatLayout
		Label:
			size_hint: 1, 1
			pos_hint: {"x": 0, "y": 0}
			halign: "center"
			valign: "center"
			id: DragAndDropLabel
			text_size: self.size
			font_size: 0.03 * self.width
			color: 0.7, 0.8, 1.0, 0.8
			text: "Drag & Drop NSP/NSZ/XCI/XCZ/NCZ files/folders here"
